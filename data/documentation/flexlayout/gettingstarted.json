":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"justify-content: center"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"FlexBox(justifyContent: .center)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"align-items: stretch","type":"codeVoice"}]}],[{"inlineContent":[{"code":"FlexBox(alignItems: .stretch)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"gap: 12px","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"FlexBox(gap: 12)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"flex: 1","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":".flexItem(flex: 1)","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flex-grow: 1"}]}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(grow: 1)","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"flex-shrink: 0","type":"codeVoice"}]}],[{"inlineContent":[{"type":"codeVoice","code":".flexItem(shrink: 0)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flex-basis: 160px"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".flexItem(basis: .points(160))"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"align-self: flex-end"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".flexItem(alignSelf: .flexEnd)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"order: -1"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".flexItem(order: -1)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"width: 50%"}]}],[{"inlineContent":[{"code":".flexItem(width: .fraction(0.5))","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"position: absolute","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":".flexItem(position: .absolute, top: 0, trailing: 0)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"z-index: 10"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(zIndex: 10)","type":"codeVoice"}]}]],[[{"inlineContent":[{"code":"overflow: hidden","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"FlexBox(overflow: .hidden)","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":".flexOverflow(.hidden)"}]}]]]},{"level":2,"type":"heading","text":"Your first FlexBox","anchor":"Your-first-FlexBox"},{"syntax":"swift","code":["import SwiftUI","import FlexLayout","","struct NavBar: View {","    var body: some View {","        FlexBox(","            direction:      .row,","            alignItems:     .center,","            justifyContent: .spaceBetween,","            padding:        EdgeInsets(top: 12, leading: 16, bottom: 12, trailing: 16)","        ) {","            Text(\"🌟 MyApp\")","                .font(.headline)","","            \/\/ This spacer grows to push the button to the right","            Color.clear.flexItem(grow: 1)","","            Button(\"Sign in\") { }","        }","        .background(Color(.systemBackground))","        .shadow(radius: 2)","    }","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Card grid","anchor":"Card-grid"},{"inlineContent":[{"type":"text","text":"A wrapping grid where cards have a minimum width of 160 pt:"}],"type":"paragraph"},{"type":"codeListing","code":["struct CardGrid: View {","    let items: [Item]","","    var body: some View {","        FlexBox(","            wrap:           .wrap,","            justifyContent: .flexStart,","            alignContent:   .flexStart,","            gap:            16,","            padding:        EdgeInsets(top: 16, leading: 16, bottom: 16, trailing: 16)","        ) {","            ForEach(items) { item in","                CardView(item: item)","                    .flexItem(basis: .points(160), grow: 1, shrink: 0)","            }","        }","    }","}"],"syntax":"swift"},{"level":2,"anchor":"Sidebar-+-content","text":"Sidebar + content","type":"heading"},{"type":"codeListing","syntax":"swift","code":["struct SidebarLayout: View {","    var body: some View {","        FlexBox(direction: .row) {","            SidebarView()","                .flexItem(basis: .points(240), shrink: 0)  \/\/ fixed-width sidebar","","            Divider()","","            ContentView()","                .flexItem(grow: 1)                          \/\/ fill remaining space","        }","    }","}"]},{"anchor":"Absolute-positioning","level":2,"text":"Absolute positioning","type":"heading"},{"inlineContent":[{"text":"Remove an item from the flex flow and pin it to the container’s corner:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["FlexBox(direction: .row, alignItems: .center, gap: 8) {","    Image(systemName: \"envelope\")","    Text(\"Inbox\")","","    \/\/ Badge floats over the icon, not in the flex flow","    Text(\"3\")","        .font(.caption2.bold())","        .padding(4)","        .background(Color.red)","        .clipShape(Circle())","        .flexItem(position: .absolute, top: -4, leading: 12)","}"],"syntax":"swift"},{"anchor":"Overflow-and-scrolling","type":"heading","level":2,"text":"Overflow and scrolling"},{"code":["\/\/ Horizontal scrolling chip bar","FlexBox(direction: .row, wrap: .nowrap, gap: 8, overflow: .scroll) {","    ForEach(tags) { tag in","        Text(tag.name)","            .padding(.horizontal, 12)","            .padding(.vertical, 6)","            .background(Capsule().fill(Color.accentColor.opacity(0.15)))","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Z-index layering","type":"heading","anchor":"Z-index-layering"},{"syntax":"swift","type":"codeListing","code":["FlexBox(direction: .row, gap: -20) {  \/\/ negative gap for overlap","    ForEach(Array(avatars.enumerated()), id: \\.offset) { i, avatar in","        AvatarView(avatar)","            .flexItem(zIndex: i)  \/\/ later avatars stack on top","    }","}"]},{"level":2,"text":"Using `FlexLayout` directly","anchor":"Using-FlexLayout-directly","type":"heading"},{"inlineContent":[{"text":"For ","type":"text"},{"type":"codeVoice","code":"AnyLayout"},{"type":"text","text":" switching or custom "},{"code":"Layout","type":"codeVoice"},{"text":" compositions, use ","type":"text"},{"code":"FlexLayout","type":"codeVoice"},{"type":"text","text":" directly:"}],"type":"paragraph"},{"code":["struct AdaptiveStack: View {","    @Environment(\\.horizontalSizeClass) var sizeClass","","    var body: some View {","        let layout: AnyLayout = (sizeClass == .compact)","            ? AnyLayout(FlexLayout(.init(direction: .column, gap: 8)))","            : AnyLayout(FlexLayout(.init(direction: .row,    gap: 16)))","","        layout {","            FeatureView()","            FeatureView()","            FeatureView()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Testing-layouts-without-SwiftUI","level":2,"text":"Testing layouts without SwiftUI","type":"heading"},{"inlineContent":[{"code":"FlexEngine","type":"codeVoice"},{"type":"text","text":" is fully decoupled from SwiftUI. Use it in plain "},{"type":"codeVoice","code":"XCTest"},{"type":"text","text":" to assert"},{"type":"text","text":" "},{"type":"text","text":"exact pixel positions:"}],"type":"paragraph"},{"code":["import XCTest","@testable import FlexLayout","","class MyLayoutTests: XCTestCase {","    func testThreeEqualColumns() {","        let solution = FlexEngine.solve(","            config: .init(direction: .row),","            inputs: [","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","            ],","            proposal: ProposedViewSize(width: 300, height: 100)","        )","","        XCTAssertEqual(solution.frames[0].width,  100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[1].minX,   100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[2].minX,   200, accuracy: 0.5)","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"article","abstract":[{"text":"Build your first flex layout in five minutes.","type":"text"}],"variants":[{"paths":["\/documentation\/flexlayout\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Articles","identifiers":["doc:\/\/FlexLayout\/documentation\/FlexLayout\/CSSPropertyReference"],"generated":true}],"references":{"doc://FlexLayout/documentation/FlexLayout":{"url":"\/documentation\/flexlayout","title":"FlexLayout","kind":"symbol","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout","role":"collection","abstract":[{"type":"text","text":"A CSS Flexbox layout engine for SwiftUI — all major flex properties, fully spec-compliant, with a pure-Swift algorithm that is independently testable."}],"type":"topic"},"doc://FlexLayout/documentation/FlexLayout/CSSPropertyReference":{"url":"\/documentation\/flexlayout\/csspropertyreference","abstract":[{"text":"Complete mapping of every CSS Flexbox property to its ","type":"text"},{"code":"FlexLayout","type":"codeVoice"},{"type":"text","text":" Swift equivalent."}],"type":"topic","kind":"article","title":"CSS Property Reference","role":"article","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout\/CSSPropertyReference"}}}