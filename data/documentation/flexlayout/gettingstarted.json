xStart,","            gap:            16,","            padding:        EdgeInsets(top: 16, leading: 16, bottom: 16, trailing: 16)","        ) {","            ForEach(items) { item in","                CardView(item: item)","                    .flexItem(basis: .points(160), grow: 1, shrink: 0)","            }","        }","    }","}"],"type":"codeListing"},{"text":"Sidebar + content","anchor":"Sidebar-+-content","type":"heading","level":2},{"type":"codeListing","syntax":"swift","code":["struct SidebarLayout: View {","    var body: some View {","        FlexBox(direction: .row) {","            SidebarView()","                .flexItem(basis: .points(240), shrink: 0)  \/\/ fixed-width sidebar","","            Divider()","","            ContentView()","                .flexItem(grow: 1)                          \/\/ fill remaining space","        }","    }","}"]},{"level":2,"text":"Absolute positioning","type":"heading","anchor":"Absolute-positioning"},{"type":"paragraph","inlineContent":[{"text":"Remove an item from the flex flow and pin it to the container’s corner:","type":"text"}]},{"code":["FlexBox(direction: .row, alignItems: .center, gap: 8) {","    Image(systemName: \"envelope\")","    Text(\"Inbox\")","","    \/\/ Badge floats over the icon, not in the flex flow","    Text(\"3\")","        .font(.caption2.bold())","        .padding(4)","        .background(Color.red)","        .clipShape(Circle())","        .flexItem(position: .absolute, top: -4, leading: 12)","}"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Overflow and scrolling","anchor":"Overflow-and-scrolling"},{"syntax":"swift","type":"codeListing","code":["\/\/ Horizontal scrolling chip bar","FlexBox(direction: .row, wrap: .nowrap, gap: 8, overflow: .scroll) {","    ForEach(tags) { tag in","        Text(tag.name)","            .padding(.horizontal, 12)","            .padding(.vertical, 6)","            .background(Capsule().fill(Color.accentColor.opacity(0.15)))","    }","}"]},{"level":2,"type":"heading","anchor":"Z-index-layering","text":"Z-index layering"},{"syntax":"swift","code":["FlexBox(direction: .row, gap: -20) {  \/\/ negative gap for overlap","    ForEach(Array(avatars.enumerated()), id: \\.offset) { i, avatar in","        AvatarView(avatar)","            .flexItem(zIndex: i)  \/\/ later avatars stack on top","    }","}"],"type":"codeListing"},{"level":2,"text":"Using `FlexLayout` directly","type":"heading","anchor":"Using-FlexLayout-directly"},{"inlineContent":[{"type":"text","text":"For "},{"type":"codeVoice","code":"AnyLayout"},{"text":" switching or custom ","type":"text"},{"code":"Layout","type":"codeVoice"},{"type":"text","text":" compositions, use "},{"type":"codeVoice","code":"FlexLayout"},{"type":"text","text":" directly:"}],"type":"paragraph"},{"syntax":"swift","code":["struct AdaptiveStack: View {","    @Environment(\\.horizontalSizeClass) var sizeClass","","    var body: some View {","        let layout: AnyLayout = (sizeClass == .compact)","            ? AnyLayout(FlexLayout(.init(direction: .column, gap: 8)))","            : AnyLayout(FlexLayout(.init(direction: .row,    gap: 16)))","","        layout {","            FeatureView()","            FeatureView()","            FeatureView()","        }","    }","}"],"type":"codeListing"},{"text":"Testing layouts without SwiftUI","anchor":"Testing-layouts-without-SwiftUI","type":"heading","level":2},{"inlineContent":[{"code":"FlexEngine","type":"codeVoice"},{"type":"text","text":" is fully decoupled from SwiftUI. Use it in plain "},{"code":"XCTest","type":"codeVoice"},{"text":" to assert","type":"text"},{"text":" ","type":"text"},{"text":"exact pixel positions:","type":"text"}],"type":"paragraph"},{"code":["import XCTest","@testable import FlexLayout","","class MyLayoutTests: XCTestCase {","    func testThreeEqualColumns() {","        let solution = FlexEngine.solve(","            config: .init(direction: .row),","            inputs: [","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","            ],","            proposal: ProposedViewSize(width: 300, height: 100)","        )","","        XCTAssertEqual(solution.frames[0].width,  100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[1].minX,   100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[2].minX,   200, accuracy: 0.5)","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/flexlayout\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://FlexLayout/documentation/FlexLayout/CSSPropertyReference":{"kind":"article","title":"CSS Property Reference","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout\/CSSPropertyReference","role":"article","url":"\/documentation\/flexlayout\/csspropertyreference","type":"topic","abstract":[{"text":"Complete mapping of every CSS Flexbox property to its ","type":"text"},{"type":"codeVoice","code":"FlexLayout"},{"text":" Swift equivalent.","type":"text"}]},"doc://FlexLayout/documentation/FlexLayout":{"role":"collection","url":"\/documentation\/flexlayout","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout","title":"FlexLayout","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A CSS Flexbox layout engine for SwiftUI — all major flex properties, fully spec-compliant, with a pure-Swift algorithm that is independently testable."}]}}}