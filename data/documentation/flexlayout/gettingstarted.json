}]],[[{"type":"paragraph","inlineContent":[{"code":"flex-direction: row","type":"codeVoice"}]}],[{"inlineContent":[{"code":"FlexBox(direction: .row)","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"flex-wrap: wrap","type":"codeVoice"}]}],[{"inlineContent":[{"type":"codeVoice","code":"FlexBox(wrap: .wrap)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"justify-content: center","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlexBox(justifyContent: .center)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"align-items: stretch"}]}],[{"inlineContent":[{"type":"codeVoice","code":"FlexBox(alignItems: .stretch)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"gap: 12px"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"FlexBox(gap: 12)","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flex: 1"}]}],[{"inlineContent":[{"type":"codeVoice","code":".flexItem(flex: 1)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"flex-grow: 1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(grow: 1)","type":"codeVoice"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"flex-shrink: 0"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(shrink: 0)","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flex-basis: 160px"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".flexItem(basis: .points(160))"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"align-self: flex-end"}]}],[{"inlineContent":[{"type":"codeVoice","code":".flexItem(alignSelf: .flexEnd)"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"order: -1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(order: -1)","type":"codeVoice"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"width: 50%"}],"type":"paragraph"}],[{"inlineContent":[{"code":".flexItem(width: .fraction(0.5))","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"position: absolute"}]}],[{"type":"paragraph","inlineContent":[{"code":".flexItem(position: .absolute, top: 0, trailing: 0)","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"z-index: 10"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".flexItem(zIndex: 10)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"overflow: hidden"}]}],[{"inlineContent":[{"code":"FlexBox(overflow: .hidden)","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":".flexOverflow(.hidden)"}],"type":"paragraph"}]]]},{"level":2,"type":"heading","text":"Your first FlexBox","anchor":"Your-first-FlexBox"},{"code":["import SwiftUI","import FlexLayout","","struct NavBar: View {","    var body: some View {","        FlexBox(","            direction:      .row,","            alignItems:     .center,","            justifyContent: .spaceBetween,","            padding:        EdgeInsets(top: 12, leading: 16, bottom: 12, trailing: 16)","        ) {","            Text(\"🌟 MyApp\")","                .font(.headline)","","            \/\/ This spacer grows to push the button to the right","            Color.clear.flexItem(grow: 1)","","            Button(\"Sign in\") { }","        }","        .background(Color(.systemBackground))","        .shadow(radius: 2)","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Card grid","level":2,"anchor":"Card-grid","type":"heading"},{"inlineContent":[{"type":"text","text":"A wrapping grid where cards have a minimum width of 160 pt:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct CardGrid: View {","    let items: [Item]","","    var body: some View {","        FlexBox(","            wrap:           .wrap,","            justifyContent: .flexStart,","            alignContent:   .flexStart,","            gap:            16,","            padding:        EdgeInsets(top: 16, leading: 16, bottom: 16, trailing: 16)","        ) {","            ForEach(items) { item in","                CardView(item: item)","                    .flexItem(basis: .points(160), grow: 1, shrink: 0)","            }","        }","    }","}"]},{"level":2,"type":"heading","text":"Sidebar + content","anchor":"Sidebar-+-content"},{"code":["struct SidebarLayout: View {","    var body: some View {","        FlexBox(direction: .row) {","            SidebarView()","                .flexItem(basis: .points(240), shrink: 0)  \/\/ fixed-width sidebar","","            Divider()","","            ContentView()","                .flexItem(grow: 1)                          \/\/ fill remaining space","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"heading","level":2,"text":"Absolute positioning","anchor":"Absolute-positioning"},{"inlineContent":[{"type":"text","text":"Remove an item from the flex flow and pin it to the container’s corner:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["FlexBox(direction: .row, alignItems: .center, gap: 8) {","    Image(systemName: \"envelope\")","    Text(\"Inbox\")","","    \/\/ Badge floats over the icon, not in the flex flow","    Text(\"3\")","        .font(.caption2.bold())","        .padding(4)","        .background(Color.red)","        .clipShape(Circle())","        .flexItem(position: .absolute, top: -4, leading: 12)","}"]},{"anchor":"Overflow-and-scrolling","level":2,"text":"Overflow and scrolling","type":"heading"},{"code":["\/\/ Horizontal scrolling chip bar","FlexBox(direction: .row, wrap: .nowrap, gap: 8, overflow: .scroll) {","    ForEach(tags) { tag in","        Text(tag.name)","            .padding(.horizontal, 12)","            .padding(.vertical, 6)","            .background(Capsule().fill(Color.accentColor.opacity(0.15)))","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Z-index-layering","text":"Z-index layering","type":"heading","level":2},{"syntax":"swift","code":["FlexBox(direction: .row, gap: -20) {  \/\/ negative gap for overlap","    ForEach(Array(avatars.enumerated()), id: \\.offset) { i, avatar in","        AvatarView(avatar)","            .flexItem(zIndex: i)  \/\/ later avatars stack on top","    }","}"],"type":"codeListing"},{"type":"heading","level":2,"text":"Using `FlexLayout` directly","anchor":"Using-FlexLayout-directly"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For "},{"type":"codeVoice","code":"AnyLayout"},{"text":" switching or custom ","type":"text"},{"type":"codeVoice","code":"Layout"},{"type":"text","text":" compositions, use "},{"type":"codeVoice","code":"FlexLayout"},{"text":" directly:","type":"text"}]},{"code":["struct AdaptiveStack: View {","    @Environment(\\.horizontalSizeClass) var sizeClass","","    var body: some View {","        let layout: AnyLayout = (sizeClass == .compact)","            ? AnyLayout(FlexLayout(.init(direction: .column, gap: 8)))","            : AnyLayout(FlexLayout(.init(direction: .row,    gap: 16)))","","        layout {","            FeatureView()","            FeatureView()","            FeatureView()","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Testing-layouts-without-SwiftUI","text":"Testing layouts without SwiftUI"},{"inlineContent":[{"code":"FlexEngine","type":"codeVoice"},{"type":"text","text":" is fully decoupled from SwiftUI. Use it in plain "},{"type":"codeVoice","code":"XCTest"},{"type":"text","text":" to assert"},{"text":" ","type":"text"},{"text":"exact pixel positions:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import XCTest","@testable import FlexLayout","","class MyLayoutTests: XCTestCase {","    func testThreeEqualColumns() {","        let solution = FlexEngine.solve(","            config: .init(direction: .row),","            inputs: [","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","                .fixed(width: 0, height: 50, grow: 1),","            ],","            proposal: ProposedViewSize(width: 300, height: 100)","        )","","        XCTAssertEqual(solution.frames[0].width,  100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[1].minX,   100, accuracy: 0.5)","        XCTAssertEqual(solution.frames[2].minX,   200, accuracy: 0.5)","    }","}"]}],"kind":"content"}],"references":{"doc://FlexLayout/documentation/FlexLayout/CSSPropertyReference":{"abstract":[{"text":"Complete mapping of every CSS Flexbox property to its ","type":"text"},{"type":"codeVoice","code":"FlexLayout"},{"text":" Swift equivalent.","type":"text"}],"url":"\/documentation\/flexlayout\/csspropertyreference","role":"article","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout\/CSSPropertyReference","kind":"article","type":"topic","title":"CSS Property Reference"},"doc://FlexLayout/documentation/FlexLayout":{"title":"FlexLayout","type":"topic","kind":"symbol","role":"collection","identifier":"doc:\/\/FlexLayout\/documentation\/FlexLayout","url":"\/documentation\/flexlayout","abstract":[{"type":"text","text":"A CSS Flexbox layout engine for SwiftUI — all major flex properties, fully spec-compliant, with a pure-Swift algorithm that is independently testable."}]}}}