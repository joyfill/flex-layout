{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#card": {
      "display": "flex",
      "position": "relative",
      "overflow": "hidden",
      "width":  { "value": 200, "unit": "px" },
      "height": { "value": 120, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    ".tile": {
      "position": "absolute",
      "width":  { "value": 160, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": {
      "top":  { "value": 10, "unit": "px" },
      "left": { "value": -40, "unit": "px" },
      "backgroundColor": "#EF4444",
      "zIndex": 1
    },
    "#b": {
      "top":  { "value": 10, "unit": "px" },
      "left": { "value": 80, "unit": "px" },
      "backgroundColor": "#10B981",
      "zIndex": 999
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "card" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["tile"] } },
          { "type": "div", "props": { "id": "b", "className": ["tile"] } }
        ]
      }
    ]
  }
}
