{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "width":  { "value": 160, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".clipped": {
      "overflow": "hidden"
    },
    ".big-child": {
      "width":  { "value": 240, "unit": "px" },
      "height": { "value": 140, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444",
      "flexShrink": 0
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root", "className": ["clipped"] },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["big-child"] } }
    ]
  }
}
