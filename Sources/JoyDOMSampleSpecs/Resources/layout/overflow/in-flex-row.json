{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".clipper": {
      "display": "flex",
      "flexDirection": "row",
      "width":  { "value": 140, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "overflow": "hidden",
      "flexShrink": 0
    },
    ".bleeder": {
      "display": "flex",
      "flexDirection": "row",
      "width":  { "value": 140, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "overflow": "visible",
      "flexShrink": 0
    },
    ".big-child": {
      "width":  { "value": 200, "unit": "px" },
      "height": { "value": 140, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexShrink": 0
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "left", "className": ["clipper"] },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["big-child"] } }
        ]
      },
      {
        "type": "div",
        "props": { "id": "right", "className": ["bleeder"] },
        "children": [
          { "type": "div", "props": { "id": "b", "className": ["big-child"] } }
        ]
      }
    ]
  }
}
