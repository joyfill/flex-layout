{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".cell": {
      "display": "flex",
      "flexDirection": "row",
      "width":  { "value": 90, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "padding": { "value": 6, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "flexShrink": 0
    },
    ".big": {
      "width":  { "value": 150, "unit": "px" },
      "height": { "value": 110, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexShrink": 0
    },
    "#visible": { "overflow": "visible" },
    "#hidden":  { "overflow": "hidden" },
    "#scroll":  { "overflow": "scroll" },
    "#auto":    { "overflow": "auto" },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" },
    "#c": { "backgroundColor": "#3B82F6" },
    "#d": { "backgroundColor": "#F59E0B" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "visible", "className": ["cell"] }, "children": [{ "type": "div", "props": { "id": "a", "className": ["big"] } }] },
      { "type": "div", "props": { "id": "hidden",  "className": ["cell"] }, "children": [{ "type": "div", "props": { "id": "b", "className": ["big"] } }] },
      { "type": "div", "props": { "id": "scroll",  "className": ["cell"] }, "children": [{ "type": "div", "props": { "id": "c", "className": ["big"] } }] },
      { "type": "div", "props": { "id": "auto",    "className": ["cell"] }, "children": [{ "type": "div", "props": { "id": "d", "className": ["big"] } }] }
    ]
  }
}
