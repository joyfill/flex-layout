{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "padding": { "value": 16, "unit": "px" },
      "width":  { "value": 240, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#frame": {
      "display": "flex",
      "position": "relative",
      "overflow": "hidden",
      "width":  { "value": 160, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#a": {
      "position": "absolute",
      "top":  { "value": -20, "unit": "px" },
      "left": { "value": -20, "unit": "px" },
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "frame" },
        "children": [
          { "type": "div", "props": { "id": "a" } }
        ]
      }
    ]
  }
}
