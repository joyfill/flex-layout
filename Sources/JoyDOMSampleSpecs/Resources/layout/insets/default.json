{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "position": "relative",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8, "unit": "px" },
      "width":  { "value": 240, "unit": "px" },
      "height": { "value": 120, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": {
      "position": "absolute",
      "backgroundColor": "#EF4444"
    },
    "#b": { "backgroundColor": "#10B981" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } }
    ]
  }
}
