{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "position": "relative",
      "width":  { "value": 240, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#a": {
      "position": "absolute",
      "top":  { "value": 0, "unit": "px" },
      "left": { "value": 0, "unit": "px" },
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#F59E0B"
    }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#a": {
          "top":  { "value": 40, "unit": "px" },
          "left": { "value": 80, "unit": "px" }
        }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a" } }
    ]
  }
}
