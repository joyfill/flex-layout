{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".card": {
      "display": "flex",
      "width":  { "value": 100, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#border-box": {
      "boxSizing": "border-box",
      "backgroundColor": "#EF4444"
    },
    "#content-box": {
      "backgroundColor": "#10B981"
    },
    ".inner": {
      "display": "flex",
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 40, "unit": "px" },
      "backgroundColor": "#FBBF24"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "border-box", "className": ["card"] },
        "children": [{ "type": "div", "props": { "id": "inner-b", "className": ["inner"] } }]
      },
      {
        "type": "div",
        "props": { "id": "content-box", "className": ["card"] },
        "children": [{ "type": "div", "props": { "id": "inner-c", "className": ["inner"] } }]
      }
    ]
  }
}
