{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "boxSizing": "border-box",
      "width":  { "value": 200, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444"
    },
    "#middle": {
      "display": "flex",
      "boxSizing": "border-box",
      "width":  { "value": 160, "unit": "px" },
      "height": { "value": 120, "unit": "px" },
      "padding": { "value": 12, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#10B981"
    },
    "#inner": {
      "display": "flex",
      "boxSizing": "border-box",
      "width":  { "value": 120, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#3B82F6"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          {
            "type": "div",
            "props": { "id": "middle" },
            "children": [
              { "type": "div", "props": { "id": "inner" } }
            ]
          }
        ]
      }
    ]
  }
}
