{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".card": {
      "display": "flex",
      "padding": { "value": 16, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#border-box": {
      "boxSizing": "border-box",
      "width":  { "value": 120, "unit": "px" },
      "height": { "value": 120, "unit": "px" },
      "backgroundColor": "#EF4444"
    },
    "#content-box": {
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "backgroundColor": "#10B981"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "border-box", "className": ["card"] } },
      { "type": "div", "props": { "id": "content-box", "className": ["card"] } }
    ]
  }
}
