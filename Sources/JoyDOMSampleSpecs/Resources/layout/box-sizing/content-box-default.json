{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#card": {
      "display": "flex",
      "width":  { "value": 120, "unit": "px" },
      "height": { "value": 120, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderColor": "#111827",
      "borderStyle": "solid",
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#10B981"
    },
    "#inner": {
      "display": "flex",
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "backgroundColor": "#FBBF24",
      "borderRadius": { "value": 2, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "card" },
        "children": [{ "type": "div", "props": { "id": "inner" } }]
      }
    ]
  }
}
