{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "width":   { "value": 360, "unit": "px" },
      "height":  { "value": 220, "unit": "px" },
      "position": "relative",
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "width":   { "value": 220, "unit": "px" },
      "height":  { "value": 160, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 12, "unit": "px" },
      "width":   { "value": 160, "unit": "px" },
      "height":  { "value": 120, "unit": "px" },
      "position": "relative",
      "backgroundColor": "#D1D5DB"
    },
    "#pinned": {
      "backgroundColor": "#EF4444",
      "position": "absolute",
      "top":  { "value": 10, "unit": "px" },
      "right":{ "value": 10, "unit": "px" },
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          {
            "type": "div",
            "props": { "id": "inner" },
            "children": [
              { "type": "div", "props": { "id": "pinned" } }
            ]
          }
        ]
      }
    ]
  }
}
