{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 12, "unit": "px" },
      "width": { "value": 240, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "borderWidth": { "value": 3, "unit": "px" },
      "borderColor": "#000000",
      "borderStyle": "solid",
      "backgroundColor": "#E5E7EB"
    },
    ".box": {
      "width": { "value": 60, "unit": "px" },
      "height": { "value": 50, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" },
    "#c": { "backgroundColor": "#3B82F6" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["box"] } },
          { "type": "div", "props": { "id": "b", "className": ["box"] } },
          { "type": "div", "props": { "id": "c", "className": ["box"] } }
        ]
      }
    ]
  }
}
