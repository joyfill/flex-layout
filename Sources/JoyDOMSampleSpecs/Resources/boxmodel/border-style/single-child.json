{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "padding": { "value": 12, "unit": "px" },
      "width": { "value": 160, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "borderWidth": { "value": 3, "unit": "px" },
      "borderColor": "#000000",
      "borderStyle": "solid",
      "backgroundColor": "#E5E7EB"
    },
    "#inner": {
      "width": { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "backgroundColor": "#3B82F6"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "inner" } }
        ]
      }
    ]
  }
}
