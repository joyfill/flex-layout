{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width": { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "borderWidth": { "value": 8, "unit": "px" },
      "borderColor": "#EF4444",
      "backgroundColor": "#E5E7EB"
    },
    "#a": { "borderStyle": "solid" },
    "#b": { "borderStyle": "none" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } }
    ]
  }
}
