{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 12, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#3B82F6"
    },
    ".box": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#F59E0B" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["box"] } },
          { "type": "div", "props": { "id": "b", "className": ["box"] } }
        ]
      }
    ]
  }
}
