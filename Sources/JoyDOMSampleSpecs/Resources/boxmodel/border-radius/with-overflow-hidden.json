{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#a": {
      "width":  { "value": 160, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "borderRadius": { "value": 24, "unit": "px" },
      "overflow": "hidden"
    },
    "#child": {
      "width":  { "value": 220, "unit": "px" },
      "height": { "value": 140, "unit": "px" },
      "backgroundColor": "#3B82F6"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "a" },
        "children": [
          { "type": "div", "props": { "id": "child" } }
        ]
      }
    ]
  }
}
