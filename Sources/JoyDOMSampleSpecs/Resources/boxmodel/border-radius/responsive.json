{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#a": {
      "width":  { "value": 120, "unit": "px" },
      "height": { "value": 80,  "unit": "px" },
      "backgroundColor": "#EF4444",
      "borderRadius": { "value": 4, "unit": "px" }
    }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#a": {
          "borderRadius": { "value": 32, "unit": "px" }
        }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a" } }
    ]
  }
}
