{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 12, "unit": "px" },
      "gap":     { "value": 0,  "unit": "px" },
      "width":   { "value": 280, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 0,  "unit": "px" },
      "width":   { "value": 200, "unit": "px" },
      "height":  { "value": 80, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "margin": { "value": 16, "unit": "px" }
    },
    ".inner": {
      "width":  { "value": 50, "unit": "px" },
      "height": { "value": 50, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "margin": { "value": 6, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["inner"] } },
          { "type": "div", "props": { "id": "b", "className": ["inner"] } }
        ]
      }
    ]
  }
}
