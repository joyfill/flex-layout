{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#full":  { "color": "#111827", "fontSize": { "value": 18, "unit": "px" }, "opacity": 1 },
    "#half":  { "color": "#111827", "fontSize": { "value": 18, "unit": "px" }, "opacity": 0.5 },
    "#faded": { "color": "#111827", "fontSize": { "value": 18, "unit": "px" }, "opacity": 0.25 }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "full"  }, "children": ["Opacity 1.0"] },
      { "type": "p", "props": { "id": "half"  }, "children": ["Opacity 0.5"] },
      { "type": "p", "props": { "id": "faded" }, "children": ["Opacity 0.25"] }
    ]
  }
}
