{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 20, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "width": { "value": 320, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 12, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "row",
      "padding": {
        "top":    { "value":  4, "unit": "px" },
        "right":  { "value": 12, "unit": "px" },
        "bottom": { "value":  4, "unit": "px" },
        "left":   { "value": 12, "unit": "px" }
      },
      "backgroundColor": "#10B981"
    },
    ".inner-box": {
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 40, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          {
            "type": "div",
            "props": { "id": "inner" },
            "children": [
              { "type": "div", "props": { "id": "a", "className": ["inner-box"] } }
            ]
          }
        ]
      }
    ]
  }
}
