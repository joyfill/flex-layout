{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 12, "unit": "px" },
      "padding": { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#uniform": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#sides": {
      "display": "flex",
      "flexDirection": "row",
      "padding": {
        "top":    { "value":  8, "unit": "px" },
        "right":  { "value": 24, "unit": "px" },
        "bottom": { "value":  8, "unit": "px" },
        "left":   { "value": 24, "unit": "px" }
      },
      "backgroundColor": "#E5E7EB"
    },
    ".box": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "uniform" }, "children": [
        { "type": "div", "props": { "id": "a", "className": ["box"] } }
      ]},
      { "type": "div", "props": { "id": "sides" }, "children": [
        { "type": "div", "props": { "id": "b", "className": ["box"] } }
      ]}
    ]
  }
}
