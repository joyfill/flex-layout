{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#parent": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 12, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderStyle": "solid",
      "borderColor": "#EF4444",
      "backgroundColor": "#E5E7EB"
    },
    ".child": {
      "width":  { "value": 50, "unit": "px" },
      "height": { "value": 50, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#10B981" },
    "#b": { "backgroundColor": "#3B82F6" },
    "#c": { "backgroundColor": "#F59E0B" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "parent" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["child"] } },
          { "type": "div", "props": { "id": "b", "className": ["child"] } },
          { "type": "div", "props": { "id": "c", "className": ["child"] } }
        ]
      }
    ]
  }
}
