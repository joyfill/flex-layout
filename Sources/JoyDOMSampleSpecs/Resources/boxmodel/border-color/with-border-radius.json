{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "borderWidth": { "value": 4, "unit": "px" },
      "borderStyle": "solid",
      "borderColor": "#3B82F6",
      "backgroundColor": "#F3F4F6"
    },
    "#pill":   { "borderRadius": { "value": 999, "unit": "px" } },
    "#square": { "borderRadius": { "value": 0, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "pill",   "className": ["box"] } },
      { "type": "div", "props": { "id": "square", "className": ["box"] } }
    ]
  }
}
