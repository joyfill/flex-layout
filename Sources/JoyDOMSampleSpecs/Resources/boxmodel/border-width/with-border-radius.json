{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "borderWidth": { "value": 6, "unit": "px" },
      "borderColor": "#000000",
      "borderStyle": "solid"
    },
    "#a": { "backgroundColor": "#EF4444", "borderRadius": { "value": 4,  "unit": "px" } },
    "#b": { "backgroundColor": "#10B981", "borderRadius": { "value": 20, "unit": "px" } },
    "#c": { "backgroundColor": "#3B82F6", "borderRadius": { "value": 40, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } },
      { "type": "div", "props": { "id": "c", "className": ["box"] } }
    ]
  }
}
