{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "gap": { "value": 8, "unit": "px" }
    },
    "#u-red":  { "textDecoration": "underline",    "color": "#D32F2F", "fontSize": { "value": 24, "unit": "px" } },
    "#u-blue": { "textDecoration": "underline",    "color": "#1976D2", "fontSize": { "value": 24, "unit": "px" } },
    "#s-red":  { "textDecoration": "line-through", "color": "#D32F2F", "fontSize": { "value": 24, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "u-red"  }, "children": ["Red underline"] },
      { "type": "p", "props": { "id": "u-blue" }, "children": ["Blue underline"] },
      { "type": "p", "props": { "id": "s-red"  }, "children": ["Red strikethrough"] }
    ]
  }
}
