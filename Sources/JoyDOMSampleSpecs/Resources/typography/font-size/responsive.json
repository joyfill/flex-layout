{
  "version": 1,
  "style": {
    "#root": { "padding": { "value": 16, "unit": "px" }, "backgroundColor": "#F3F4F6" },
    "#t":    { "fontSize": { "value": 14, "unit": "px" } }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#t": { "fontSize": { "value": 32, "unit": "px" } }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "t" }, "children": ["Responsive: 14px narrow / 32px ≥768px"] }
    ]
  }
}
