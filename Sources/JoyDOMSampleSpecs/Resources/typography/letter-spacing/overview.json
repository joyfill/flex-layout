{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#tracked": { "fontSize": { "value": 22, "unit": "px" }, "letterSpacing": { "value": 1, "unit": "px" } },
    "#em":      { "fontSize": { "value": 18, "unit": "px" }, "letterSpacing": { "value": 0.05, "unit": "em" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "tracked" }, "children": ["Tracked letters."] },
      { "type": "p", "props": { "id": "em"      }, "children": ["Em-tracked letters."] }
    ]
  }
}
