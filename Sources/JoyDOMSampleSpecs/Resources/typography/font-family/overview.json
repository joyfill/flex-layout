{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 6, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#headline":  { "fontFamily": "Libre Baskerville", "fontSize": { "value": 28, "unit": "px" } },
    "#body":      { "fontFamily": "Geist",            "fontSize": { "value": 16, "unit": "px" } },
    "#code":      { "fontFamily": "Geist Mono",        "fontSize": { "value": 14, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "h1", "props": { "id": "headline" }, "children": ["Hello, joy-dom!"] },
      { "type": "p",  "props": { "id": "body"     }, "children": ["A short paragraph in Geist."] },
      { "type": "p",  "props": { "id": "code"     }, "children": ["fontFamily: 'Geist Mono'"] }
    ]
  }
}
