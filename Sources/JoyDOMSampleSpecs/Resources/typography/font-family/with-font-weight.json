{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#regular":   { "fontFamily": "Helvetica Neue", "fontSize": { "value": 20, "unit": "px" }, "fontWeight": "normal" },
    "#bold":      { "fontFamily": "Helvetica Neue", "fontSize": { "value": 20, "unit": "px" }, "fontWeight": "bold" },
    "#weight300": { "fontFamily": "Helvetica Neue", "fontSize": { "value": 20, "unit": "px" }, "fontWeight": 300 },
    "#weight700": { "fontFamily": "Helvetica Neue", "fontSize": { "value": 20, "unit": "px" }, "fontWeight": 700 }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "regular"   }, "children": ["Helvetica Neue regular"] },
      { "type": "p", "props": { "id": "bold"      }, "children": ["Helvetica Neue bold"] },
      { "type": "p", "props": { "id": "weight300" }, "children": ["Helvetica Neue 300"] },
      { "type": "p", "props": { "id": "weight700" }, "children": ["Helvetica Neue 700"] }
    ]
  }
}
