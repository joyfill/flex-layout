{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#serif": { "fontFamily": "Georgia",   "fontSize": { "value": 20, "unit": "px" } },
    "#sans":  { "fontFamily": "Helvetica", "fontSize": { "value": 20, "unit": "px" } },
    "#mono":  { "fontFamily": "Menlo",     "fontSize": { "value": 20, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "serif" }, "children": ["Serif Georgia"] },
      { "type": "p", "props": { "id": "sans"  }, "children": ["Sans Helvetica"] },
      { "type": "p", "props": { "id": "mono"  }, "children": ["Mono Menlo"] }
    ]
  }
}
