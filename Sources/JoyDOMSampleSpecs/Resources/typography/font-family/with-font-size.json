{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#small":  { "fontFamily": "LibreBaskerville", "fontSize": { "value": 12, "unit": "px" } },
    "#medium": { "fontFamily": "LibreBaskerville", "fontSize": { "value": 20, "unit": "px" } },
    "#large":  { "fontFamily": "LibreBaskerville", "fontSize": { "value": 32, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "small"  }, "children": ["Libre Baskerville 12px"] },
      { "type": "p", "props": { "id": "medium" }, "children": ["Libre Baskerville 20px"] },
      { "type": "p", "props": { "id": "large"  }, "children": ["Libre Baskerville 32px"] }
    ]
  }
}
