{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 12, "unit": "px" },
      "gap": { "value": 6, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#tight":   { "textTransform": "uppercase", "fontSize": { "value": 20, "unit": "px" } },
    "#tracked": { "textTransform": "uppercase", "fontSize": { "value": 20, "unit": "px" }, "letterSpacing": { "value": 2, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "tight" },   "children": ["uppercase tight"] },
      { "type": "p", "props": { "id": "tracked" }, "children": ["uppercase tracked"] }
    ]
  }
}
