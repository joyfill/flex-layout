{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 12, "unit": "px" },
      "gap": { "value": 6, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#serif": { "textTransform": "uppercase", "fontFamily": "LibreBaskerville", "fontSize": { "value": 22, "unit": "px" } },
    "#sans":  { "textTransform": "uppercase", "fontFamily": "Geist", "fontSize": { "value": 22, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "serif" }, "children": ["Serif Caps Heading"] },
      { "type": "p", "props": { "id": "sans" },  "children": ["Sans Caps Heading"] }
    ]
  }
}
