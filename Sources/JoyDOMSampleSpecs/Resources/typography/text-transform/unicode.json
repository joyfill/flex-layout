{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 12, "unit": "px" },
      "gap": { "value": 6, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#accents": { "textTransform": "uppercase", "fontSize": { "value": 20, "unit": "px" } },
    "#emoji":   { "textTransform": "uppercase", "fontSize": { "value": 20, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "accents" }, "children": ["café résumé naïve"] },
      { "type": "p", "props": { "id": "emoji" },   "children": ["hello 👋 world 🌍"] }
    ]
  }
}
