{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".danger":  { "color": "#EF4444" },
    ".success": { "color": "#10B981" },
    ".info":    { "color": "#3B82F6" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "a", "className": ["danger"] },  "children": [".danger class"] },
      { "type": "p", "props": { "id": "b", "className": ["success"] }, "children": [".success class"] },
      { "type": "p", "props": { "id": "c", "className": ["info"] },    "children": [".info class"] }
    ]
  }
}
