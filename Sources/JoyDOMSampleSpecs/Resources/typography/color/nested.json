{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6",
      "color": "#10B981"
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 4, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "outer" }, "children": ["Outer paragraph — green via #root"] },
      {
        "type": "div",
        "props": { "id": "inner" },
        "children": [
          { "type": "p", "props": { "id": "deep1" }, "children": ["Nested paragraph 1 — still green"] },
          { "type": "p", "props": { "id": "deep2" }, "children": ["Nested paragraph 2 — still green"] }
        ]
      }
    ]
  }
}
