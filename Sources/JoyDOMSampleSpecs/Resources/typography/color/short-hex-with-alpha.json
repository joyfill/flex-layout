{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#a": { "color": "#00ff" },
    "#b": { "color": "#00f8" },
    "#c": { "color": "#00f4" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "a" }, "children": ["#00ff — opaque blue"] },
      { "type": "p", "props": { "id": "b" }, "children": ["#00f8 — half blue"] },
      { "type": "p", "props": { "id": "c" }, "children": ["#00f4 — faint blue"] }
    ]
  }
}
