{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#headline": { "color": "#EF4444" }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#headline": { "color": "#3B82F6" }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "headline" }, "children": ["Red narrow, blue wide ≥768px"] }
    ]
  }
}
