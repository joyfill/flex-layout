{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 24, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#plain":  { "fontFamily": "Georgia", "fontSize": { "value": 24, "unit": "px" } },
    "#italic": { "fontFamily": "Georgia", "fontSize": { "value": 24, "unit": "px" }, "fontStyle": "italic" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "plain"  }, "children": ["Georgia regular"] },
      { "type": "p", "props": { "id": "italic" }, "children": ["Georgia italic"]  }
    ]
  }
}
