{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 24, "unit": "px" },
      "gap": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "fontStyle": "italic",
      "fontSize": { "value": 22, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "p",
        "props": { "id": "outer" },
        "children": [
          "Outer italic with ",
          { "type": "span", "props": { "id": "inner" }, "children": ["nested span"] },
          " inherits italic."
        ]
      }
    ]
  }
}
