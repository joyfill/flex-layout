{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "gap": { "value": 8, "unit": "px" }
    },
    "#small":  { "fontWeight": 700, "fontSize": { "value": 14, "unit": "px" } },
    "#medium": { "fontWeight": 700, "fontSize": { "value": 24, "unit": "px" } },
    "#large":  { "fontWeight": 700, "fontSize": { "value": 40, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "small"  }, "children": ["Bold 14"] },
      { "type": "p", "props": { "id": "medium" }, "children": ["Bold 24"] },
      { "type": "p", "props": { "id": "large"  }, "children": ["Bold 40"] }
    ]
  }
}
