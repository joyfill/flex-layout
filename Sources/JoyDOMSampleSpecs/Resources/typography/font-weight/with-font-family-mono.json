{
  "version": 1,
  "style": {
    "#regular": { "fontWeight": 400, "fontFamily": "GeistMono", "fontSize": { "value": 24, "unit": "px" } },
    "#bold":    { "fontWeight": 700, "fontFamily": "GeistMono", "fontSize": { "value": 24, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
