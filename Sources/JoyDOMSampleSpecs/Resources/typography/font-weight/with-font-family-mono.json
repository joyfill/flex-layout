{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "gap": { "value": 8, "unit": "px" }
    },
    "#regular": { "fontWeight": 400, "fontFamily": "Menlo", "fontSize": { "value": 24, "unit": "px" } },
    "#bold":    { "fontWeight": 700, "fontFamily": "Menlo", "fontSize": { "value": 24, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "regular" }, "children": ["Menlo 400"] },
      { "type": "p", "props": { "id": "bold"    }, "children": ["Menlo 700"] }
    ]
  }
}
