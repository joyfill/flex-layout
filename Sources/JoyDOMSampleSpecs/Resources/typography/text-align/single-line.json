{
  "version": 1,
  "style": {
    "#root": {
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#left":   { "textAlign": "left",   "fontSize": { "value": 16, "unit": "px" }, "color": "#111827" },
    "#center": { "textAlign": "center", "fontSize": { "value": 16, "unit": "px" }, "color": "#111827" },
    "#right":  { "textAlign": "right",  "fontSize": { "value": 16, "unit": "px" }, "color": "#111827" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "p", "props": { "id": "left"   }, "children": ["Left"]   },
      { "type": "p", "props": { "id": "center" }, "children": ["Center"] },
      { "type": "p", "props": { "id": "right"  }, "children": ["Right"]  }
    ]
  }
}
