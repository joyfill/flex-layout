{
  "version": 1,
  "style": {
    "#root": {
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#title": {
      "textAlign": "center",
      "fontSize": { "value": 32, "unit": "px" },
      "color": "#111827"
    },
    "#body": {
      "textAlign": "center",
      "fontSize": { "value": 14, "unit": "px" },
      "color": "#374151"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "h1", "props": { "id": "title" }, "children": ["Large Centered Title"] },
      { "type": "p",  "props": { "id": "body"  }, "children": ["Smaller centered body text below. Demonstrates textAlign × fontSize interaction on multi-element layouts."] }
    ]
  }
}
