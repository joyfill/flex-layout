{
  "version": 1,
  "style": {
    "#root": {
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "padding": { "value": 12, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#inner": {
      "padding": { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#p": {
      "textAlign": "right",
      "fontSize": { "value": 16, "unit": "px" },
      "color": "#111827"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          {
            "type": "div",
            "props": { "id": "inner" },
            "children": [
              { "type": "p", "props": { "id": "p" }, "children": ["Nested containers: textAlign resolves against the innermost content box, not the root."] }
            ]
          }
        ]
      }
    ]
  }
