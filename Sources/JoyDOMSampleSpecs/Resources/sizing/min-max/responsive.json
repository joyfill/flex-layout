{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444", "minWidth": { "value": 60,  "unit": "px" } },
    "#b": { "backgroundColor": "#10B981", "minWidth": { "value": 60,  "unit": "px" } },
    "#c": { "backgroundColor": "#3B82F6", "minWidth": { "value": 60,  "unit": "px" } }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#a": { "minWidth": { "value": 200, "unit": "px" } },
        "#b": { "minWidth": { "value": 200, "unit": "px" } },
        "#c": { "minWidth": { "value": 200, "unit": "px" } }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } },
      { "type": "div", "props": { "id": "c", "className": ["box"] } }
    ]
  }
}
