{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "flex-start",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#a": {
      "display": "flex",
      "width":  { "value": 60, "unit": "px" },
