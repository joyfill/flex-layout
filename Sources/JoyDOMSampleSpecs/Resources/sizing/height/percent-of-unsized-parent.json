      "backgroundColor": "#EF4444",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#b": {
      "display": "flex",
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 50, "unit": "%" },
      "backgroundColor": "#10B981",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#c": {
      "display": "flex",
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "backgroundColor": "#3B82F6",
      "borderRadius": { "value": 4, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a" } },
      { "type": "div", "props": { "id": "b" } },
      { "type": "div", "props": { "id": "c" } }
    ]
