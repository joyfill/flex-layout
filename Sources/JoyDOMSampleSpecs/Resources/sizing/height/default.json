{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "flex-start",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 12, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".card": {
      "display": "flex",
      "flexDirection": "column",
      "width":  { "value": 80, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" },
    "#c": { "backgroundColor": "#3B82F6" },
    ".inner-40": {
      "display": "flex",
      "width":  { "value": 64, "unit": "px" },
      "height": { "value": 40, "unit": "px" },
      "backgroundColor": "#FBBF24",
      "borderRadius": { "value": 2, "unit": "px" }
    },
    ".inner-80": {
      "display": "flex",
      "width":  { "value": 64, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "backgroundColor": "#FBBF24",
      "borderRadius": { "value": 2, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["card"] },
        "children": [ { "type": "div", "props": { "id": "ai", "className": ["inner-40"] } } ] },
      { "type": "div", "props": { "id": "b", "className": ["card"] },
        "children": [ { "type": "div", "props": { "id": "bi", "className": ["inner-80"] } } ] },
      { "type": "div", "props": { "id": "c", "className": ["card"] },
        "children": [ { "type": "div", "props": { "id": "ci", "className": ["inner-40"] } } ] }
    ]
  }
}
