{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "width":   { "value": 400, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 6, "unit": "px" },
      "width":   { "value": 240, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".box": {
      "width":  { "value": 50, "unit": "%" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexShrink": 0
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "inner" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["box"] } },
          { "type": "div", "props": { "id": "b", "className": ["box"] } }
        ]
      }
    ]
  }
}
