{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "width":   { "value": 400, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 6, "unit": "px" },
      "width":   { "value": 75, "unit": "%" },
      "backgroundColor": "#E5E7EB",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".inner": {
      "width":  { "value": 48, "unit": "%" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexShrink": 0
    },
    "#a":    { "backgroundColor": "#EF4444" },
    "#b":    { "backgroundColor": "#10B981" },
    "#tail": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 76, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#3B82F6",
      "flexShrink": 0
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["inner"] } },
          { "type": "div", "props": { "id": "b", "className": ["inner"] } }
        ]
      },
      { "type": "div", "props": { "id": "tail" } }
    ]
  }
}
