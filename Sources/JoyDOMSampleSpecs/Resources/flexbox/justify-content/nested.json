{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "justifyContent": "flex-end",
      "padding": { "value": 16, "unit": "px" },
      "width":   { "value": 400, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer-box": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444"
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "row",
      "justifyContent": "space-between",
      "padding": { "value": 8, "unit": "px" },
      "width":   { "value": 240, "unit": "px" },
      "height":  { "value": 60,  "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    ".inner-box": {
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 44, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#g": { "backgroundColor": "#10B981" },
    "#b": { "backgroundColor": "#3B82F6" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "outer-box" } },
      {
        "type": "div",
        "props": { "id": "inner" },
        "children": [
          { "type": "div", "props": { "id": "g", "className": ["inner-box"] } },
          { "type": "div", "props": { "id": "b", "className": ["inner-box"] } }
        ]
      }
    ]
  }
}
