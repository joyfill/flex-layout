{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "width":   { "value": 320, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444", "flexBasis": { "value": 80,  "unit": "px" }, "flexShrink": 1 },
    "#b": { "backgroundColor": "#10B981", "flexBasis": { "value": 160, "unit": "px" }, "flexShrink": 1 },
    "#c": { "backgroundColor": "#3B82F6", "flexBasis": { "value": 240, "unit": "px" }, "flexShrink": 1 }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } },
      { "type": "div", "props": { "id": "c", "className": ["box"] } }
    ]
  }
}
