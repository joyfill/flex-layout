{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "width":   { "value": 300, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#fixed": {
      "width":  { "value": 60, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#EF4444",
      "flexShrink": 0
    },
    "#inner": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 12, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "height":  { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "flexShrink": 1
    },
    ".inner-box": {
      "width":  { "value": 100, "unit": "px" },
      "height": { "value": 36,  "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexShrink": 1
    },
    "#g": { "backgroundColor": "#10B981" },
    "#b": { "backgroundColor": "#3B82F6" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "fixed" } },
      {
        "type": "div",
        "props": { "id": "inner" },
        "children": [
          { "type": "div", "props": { "id": "g", "className": ["inner-box"] } },
          { "type": "div", "props": { "id": "b", "className": ["inner-box"] } }
        ]
      }
    ]
  }
}
