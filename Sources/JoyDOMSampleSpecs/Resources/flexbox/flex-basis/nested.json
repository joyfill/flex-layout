{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "width":   { "value": 400, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#outer": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 6, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "flexBasis": { "value": 240, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".box": {
      "height": { "value": 60, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexBasis": { "value": 50, "unit": "%" }
    },
    "#a": { "backgroundColor": "#EF4444" },
    "#b": { "backgroundColor": "#10B981" },
    "#tail": {
      "backgroundColor": "#3B82F6",
      "height": { "value": 76, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" },
      "flexBasis": { "value": 80, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "outer" },
        "children": [
          { "type": "div", "props": { "id": "a", "className": ["box"] } },
          { "type": "div", "props": { "id": "b", "className": ["box"] } }
        ]
      },
      { "type": "div", "props": { "id": "tail" } }
    ]
  }
}
