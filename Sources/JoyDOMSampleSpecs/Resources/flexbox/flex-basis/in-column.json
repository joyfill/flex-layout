{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 8,  "unit": "px" },
      "width":   { "value": 300, "unit": "px" },
      "height":  { "value": 400, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".box": {
      "width":  { "value": 200, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a": { "backgroundColor": "#EF4444", "flexBasis": { "value": 60,  "unit": "px" } },
    "#b": { "backgroundColor": "#10B981", "flexBasis": { "value": 120, "unit": "px" } },
    "#c": { "backgroundColor": "#3B82F6", "flexBasis": { "value": 25,  "unit": "%"  } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["box"] } },
      { "type": "div", "props": { "id": "b", "className": ["box"] } },
      { "type": "div", "props": { "id": "c", "className": ["box"] } }
    ]
  }
}
