{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".col": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 4, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".box": {
      "width":  { "value": 50, "unit": "px" },
      "height": { "value": 30, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#l1": { "backgroundColor": "#EF4444" },
    "#l2": { "backgroundColor": "#10B981" },
    "#r1": { "backgroundColor": "#3B82F6" },
    "#r2": { "backgroundColor": "#F59E0B" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "left", "className": ["col"] },
        "children": [
          { "type": "div", "props": { "id": "l1", "className": ["box"] } },
          { "type": "div", "props": { "id": "l2", "className": ["box"] } }
        ]
      },
      {
        "type": "div",
        "props": { "id": "right", "className": ["col"] },
        "children": [
          { "type": "div", "props": { "id": "r1", "className": ["box"] } },
          { "type": "div", "props": { "id": "r2", "className": ["box"] } }
        ]
      }
    ]
  }
}
