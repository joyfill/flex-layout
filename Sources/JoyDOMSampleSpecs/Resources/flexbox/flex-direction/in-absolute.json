{
  "version": 1,
  "style": {
    "#wrap": {
      "position": "relative",
      "width":  { "value": 320, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "backgroundColor": "#F9FAFB",
      "borderRadius": { "value": 8, "unit": "px" }
    },
    "#overlay": {
      "display": "flex",
      "position": "absolute",
      "top":    { "value": 16, "unit": "px" },
      "left":   { "value": 16, "unit": "px" },
      "right":  { "value": 16, "unit": "px" },
      "bottom": { "value": 16, "unit": "px" },
      "flexDirection": "row",
      "padding": { "value": 8, "unit": "px" },
      "gap":     { "value": 8, "unit": "px" },
      "backgroundColor": "#3B82F6",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".chip": {
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 40, "unit": "px" },
      "backgroundColor": "#FFFFFF",
      "borderRadius": { "value": 4, "unit": "px" }
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "wrap" },
    "children": [
      {
        "type": "div",
        "props": { "id": "overlay" },
        "children": [
          { "type": "div", "props": { "id": "1", "className": ["chip"] } },
          { "type": "div", "props": { "id": "2", "className": ["chip"] } },
          { "type": "div", "props": { "id": "3", "className": ["chip"] } }
        ]
      }
    ]
  }
}
