{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "padding": { "value": 16, "unit": "px" },
      "gap":     { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".stack": {
      "display": "flex",
      "flexDirection": "column",
      "padding": { "value": 12, "unit": "px" },
      "gap":     { "value": 6,  "unit": "px" },
      "backgroundColor": "#F3F4F6",
      "borderRadius": { "value": 4, "unit": "px" }
    },
    ".box": {
      "width":  { "value": 80, "unit": "px" },
      "height": { "value": 30, "unit": "px" },
      "borderRadius": { "value": 4, "unit": "px" }
    },
    "#a1": { "backgroundColor": "#EF4444" },
    "#a2": { "backgroundColor": "#10B981" },
    "#b1": { "backgroundColor": "#3B82F6" },
    "#b2": { "backgroundColor": "#F59E0B" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      {
        "type": "div",
        "props": { "id": "a", "className": ["stack"] },
        "children": [
          { "type": "div", "props": { "id": "a1", "className": ["box"] } },
          { "type": "div", "props": { "id": "a2", "className": ["box"] } }
        ]
      },
      {
        "type": "div",
        "props": { "id": "b", "className": ["stack"] },
        "children": [
          { "type": "div", "props": { "id": "b1", "className": ["box"] } },
          { "type": "div", "props": { "id": "b2", "className": ["box"] } }
        ]
      }
    ]
  }
}
