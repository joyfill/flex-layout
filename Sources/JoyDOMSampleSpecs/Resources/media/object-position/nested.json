{
  "version": 1,
  "style": {
    "#parent": {
      "display": "flex",
      "padding": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6",
      "objectFit": "contain",
      "objectPosition": { "horizontal": "left", "vertical": "bottom" }
    },
    "#wrap": {
      "display": "flex",
      "padding": { "value": 4, "unit": "px" }
    },
    "#child": {
      "width":  { "value": 200, "unit": "px" },
      "height": { "value": 300, "unit": "px" },
      "backgroundColor": "#111827"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "parent" },
    "children": [
      {
        "type": "div",
        "props": { "id": "wrap" },
        "children": [
          { "type": "img", "props": { "id": "child", "src": "bundle://photo-landscape" } }
        ]
      }
    ]
  }
}
