{
  "version": 1,
  "style": {
    "#img": {
      "width":  { "value": 240, "unit": "px" },
      "height": { "value": 240, "unit": "px" },
      "objectFit": "contain",
      "objectPosition": { "horizontal": "left", "vertical": "top" },
      "backgroundColor": "#111827"
    }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#img": {
          "objectPosition": { "horizontal": "right", "vertical": "bottom" }
        }
      }
    }
  ],
  "layout": {
    "type": "img",
    "props": { "id": "img", "src": "bundle://photo-landscape" }
  }
}
