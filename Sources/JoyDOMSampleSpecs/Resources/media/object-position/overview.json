{
  "version": 1,
  "style": {
    "#grid":   { "flexDirection": "column", "gap": { "value": 4, "unit": "px" }, "padding": { "value": 4, "unit": "px" }, "backgroundColor": "#111827" },
    "#row":    { "flexDirection": "row",    "gap": { "value": 4, "unit": "px" } },
    "img":     { "width": { "value": 140, "unit": "px" }, "height": { "value": 80,  "unit": "px" }, "objectFit": "cover", "backgroundColor": "#1F2937" },
    "#tl":     { "objectPosition": { "horizontal": "left",   "vertical": "top"    } },
    "#tc":     { "objectPosition": { "horizontal": "center", "vertical": "top"    } },
    "#tr":     { "objectPosition": { "horizontal": "right",  "vertical": "top"    } },
    "#cl":     { "objectPosition": { "horizontal": "left",   "vertical": "center" } },
    "#cc":     { "objectPosition": { "horizontal": "center", "vertical": "center" } },
    "#cr":     { "objectPosition": { "horizontal": "right",  "vertical": "center" } },
    "#bl":     { "objectPosition": { "horizontal": "left",   "vertical": "bottom" } },
    "#bc":     { "objectPosition": { "horizontal": "center", "vertical": "bottom" } },
    "#br":     { "objectPosition": { "horizontal": "right",  "vertical": "bottom" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "grid" },
    "children": [
      { "type": "div", "props": { "id": "rowT", "style": { "flexDirection": "row", "gap": { "value": 4, "unit": "px" } } }, "children": [
        { "type": "img", "props": { "id": "tl", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "tc", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "tr", "src": "bundle://photo-portrait" } }
      ]},
      { "type": "div", "props": { "id": "rowC", "style": { "flexDirection": "row", "gap": { "value": 4, "unit": "px" } } }, "children": [
        { "type": "img", "props": { "id": "cl", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "cc", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "cr", "src": "bundle://photo-portrait" } }
      ]},
      { "type": "div", "props": { "id": "rowB", "style": { "flexDirection": "row", "gap": { "value": 4, "unit": "px" } } }, "children": [
        { "type": "img", "props": { "id": "bl", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "bc", "src": "bundle://photo-portrait" } },
        { "type": "img", "props": { "id": "br", "src": "bundle://photo-portrait" } }
      ]}
    ]
  }
}
