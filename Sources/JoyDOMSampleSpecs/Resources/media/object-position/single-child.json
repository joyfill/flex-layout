      "display": "flex",
      "padding": { "value": 8, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#solo": {
      "width":  { "value": 200, "unit": "px" },
      "height": { "value": 300, "unit": "px" },
      "objectFit": "contain",
      "objectPosition": { "horizontal": "center", "vertical": "bottom" },
      "backgroundColor": "#111827"
    }
  },
  "breakpoints": [],
