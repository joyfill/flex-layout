{
  "version": 1,
  "style": {
    "#img": {
      "width": { "value": 240, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "objectFit": "contain",
      "backgroundColor": "#111827"
    }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#img": { "objectFit": "cover" }
      }
    }
  ],
  "layout": {
    "type": "img",
    "props": { "id": "img", "src": "bundle://photo-portrait" }
  }
}
