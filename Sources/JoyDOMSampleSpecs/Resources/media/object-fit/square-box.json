{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".sq": {
      "width": { "value": 100, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    "#a": { "objectFit": "contain" },
    "#b": { "objectFit": "cover" },
    "#c": { "objectFit": "fill" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "img", "props": { "id": "a", "className": ["sq"], "src": "https://example.com/photo.jpg" } },
      { "type": "img", "props": { "id": "b", "className": ["sq"], "src": "https://example.com/photo.jpg" } },
      { "type": "img", "props": { "id": "c", "className": ["sq"], "src": "https://example.com/photo.jpg" } }
    ]
  }
}
