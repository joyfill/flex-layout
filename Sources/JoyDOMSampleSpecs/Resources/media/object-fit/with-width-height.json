{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    "#wide": {
      "width": { "value": 240, "unit": "px" },
      "height": { "value": 60, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "objectFit": "cover"
    },
    "#tall": {
      "width": { "value": 60, "unit": "px" },
      "height": { "value": 240, "unit": "px" },
      "backgroundColor": "#E5E7EB",
      "objectFit": "cover"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "img", "props": { "id": "wide", "src": "https://example.com/photo.jpg" } },
      { "type": "img", "props": { "id": "tall", "src": "https://example.com/photo.jpg" } }
    ]
  }
}
