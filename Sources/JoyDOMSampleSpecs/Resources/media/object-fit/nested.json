{
  "version": 1,
  "style": {
    "#parent": { "objectFit": "contain", "padding": { "value": 8, "unit": "px" }, "backgroundColor": "#111827" },
    "#img":    { "width": { "value": 240, "unit": "px" }, "height": { "value": 160, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "parent" },
    "children": [
      {
        "type": "div",
        "children": [
          { "type": "img", "props": { "id": "img", "src": "bundle://photo-portrait" } }
        ]
      }
    ]
  }
}
