{
  "version": 1,
  "style": {
    "#gallery":     { "flexDirection": "column", "gap": { "value": 8, "unit": "px" }, "padding": { "value": 8, "unit": "px" }, "backgroundColor": "#F3F4F6" },
    "#fill":        { "width": { "value": 240, "unit": "px" }, "height": { "value": 100, "unit": "px" }, "objectFit": "fill" },
    "#contain":     { "width": { "value": 240, "unit": "px" }, "height": { "value": 100, "unit": "px" }, "objectFit": "contain" },
    "#cover":       { "width": { "value": 240, "unit": "px" }, "height": { "value": 100, "unit": "px" }, "objectFit": "cover" },
    "#none":        { "width": { "value": 240, "unit": "px" }, "height": { "value": 100, "unit": "px" }, "objectFit": "none" },
    "#scale-down":  { "width": { "value": 240, "unit": "px" }, "height": { "value": 100, "unit": "px" }, "objectFit": "scale-down" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "gallery" },
    "children": [
      { "type": "img", "props": { "id": "fill",       "src": "bundle://photo-landscape" } },
      { "type": "img", "props": { "id": "contain",    "src": "bundle://photo-portrait"  } },
      { "type": "img", "props": { "id": "cover",      "src": "bundle://photo-portrait"  } },
      { "type": "img", "props": { "id": "none",       "src": "bundle://photo-landscape" } },
      { "type": "img", "props": { "id": "scale-down", "src": "bundle://photo-landscape" } }
    ]
  }
}
