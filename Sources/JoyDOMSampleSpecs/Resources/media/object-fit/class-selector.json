{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "column",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".thumb": {
      "width": { "value": 200, "unit": "px" },
      "height": { "value": 80, "unit": "px" },
      "backgroundColor": "#E5E7EB"
    },
    ".contain": { "objectFit": "contain" },
    ".cover":   { "objectFit": "cover" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "img", "props": { "id": "a", "className": ["thumb", "contain"], "src": "https://example.com/photo.jpg" } },
      { "type": "img", "props": { "id": "b", "className": ["thumb", "cover"],   "src": "https://example.com/photo.jpg" } }
    ]
  }
}
