{
  "version": 1,
  "style": {
    "#row": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 8, "unit": "px" },
      "width":  { "value": 320, "unit": "px" },
      "height": { "value": 160, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".swatch": {
      "width":  { "value": 40, "unit": "px" },
      "height": { "value": 40, "unit": "px" }
    },
    "#a":   { "backgroundColor": "#EF4444" },
    "#b":   { "backgroundColor": "#3B82F6" },
    "#img": { "flexGrow": 1, "height": { "value": 144, "unit": "px" }, "objectFit": "cover" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "row" },
    "children": [
      { "type": "div", "props": { "id": "a", "className": ["swatch"] } },
      { "type": "img", "props": { "id": "img", "src": "bundle://photo-portrait" } },
      { "type": "div", "props": { "id": "b", "className": ["swatch"] } }
    ]
  }
}
