{
  "version": 1,
  "style": {
    "#root": {
      "display": "flex",
      "flexDirection": "row",
      "gap": { "value": 8, "unit": "px" },
      "padding": { "value": 16, "unit": "px" },
      "backgroundColor": "#F3F4F6"
    },
    ".thumb": {
      "width": { "value": 100, "unit": "px" },
      "height": { "value": 100, "unit": "px" },
      "backgroundColor": "#3B82F6",
      "borderRadius": { "value": 50, "unit": "px" },
      "objectFit": "cover"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "img", "props": { "id": "a", "className": ["thumb"], "src": "https://example.com/photo.jpg" } },
      { "type": "img", "props": { "id": "b", "className": ["thumb"], "src": "https://example.com/photo.jpg" } }
    ]
  }
}
