{
  "version": 1,
  "style": {
    "#frame":  { "display": "flex", "flexDirection": "column", "gap": { "value": 6, "unit": "px" }, "width": { "value": 220, "unit": "px" } },
    "#small":  { "whiteSpace": "nowrap", "fontSize": { "value": 12, "unit": "px" } },
    "#medium": { "whiteSpace": "nowrap", "fontSize": { "value": 18, "unit": "px" } },
    "#large":  { "whiteSpace": "nowrap", "fontSize": { "value": 28, "unit": "px" } }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "props": { "id": "small"  }, "children": ["Nowrap line at 12px overflowing"] },
      { "type": "p", "props": { "id": "medium" }, "children": ["Nowrap line at 18px overflowing"] },
      { "type": "p", "props": { "id": "large"  }, "children": ["Nowrap line at 28px overflowing"] }
    ]
  }
}
