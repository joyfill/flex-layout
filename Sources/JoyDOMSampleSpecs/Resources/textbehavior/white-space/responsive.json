{
  "version": 1,
  "style": {
    "#frame": { "width": { "value": 200, "unit": "px" } },
    "p":      { "whiteSpace": "normal" }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "p": { "whiteSpace": "nowrap" }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "children": ["normal narrow wraps; nowrap wide single line at >=768px"] }
    ]
  }
}
