{
  "version": 1,
  "style": {
    "#frame": {
      "height": {
        "value": 180,
        "unit": "px"
      },
      "display": "flex",
      "flexDirection": "column",
      "gap": {
        "value": 4,
        "unit": "px"
      },
      "width": {
        "value": 220,
        "unit": "px"
      }
    },
    "#wrap": {
      "whiteSpace": "normal"
    },
    "#one-line": {
      "whiteSpace": "nowrap"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": {
      "id": "frame"
    },
    "children": [
      {
        "type": "p",
        "props": {
          "id": "wrap"
        },
        "children": [
          "normal: wraps as needed across multiple lines."
        ]
      },
      {
        "type": "p",
        "props": {
          "id": "one-line"
        },
        "children": [
          "nowrap: stays on a single line and overflows."
        ]
      }
    ]
  }
}
