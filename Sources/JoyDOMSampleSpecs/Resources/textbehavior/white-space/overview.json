{
  "version": 1,
  "style": {
    "#frame":    { "width": { "value": 220, "unit": "px" } },
    "#wrap":     { "whiteSpace": "normal" },
    "#one-line": { "whiteSpace": "nowrap" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "props": { "id": "wrap"     }, "children": ["normal: wraps as needed across multiple lines."] },
      { "type": "p", "props": { "id": "one-line" }, "children": ["nowrap: stays on a single line and overflows."] }
    ]
  }
}
