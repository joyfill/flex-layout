{
  "version": 1,
  "style": {
    "#frame":      { "display": "flex", "flexDirection": "column", "gap": { "value": 4, "unit": "px" }, "width": { "value": 200, "unit": "px" } },
    "#wrapId":     { "whiteSpace": "normal" },
    "#nowrapId":   { "whiteSpace": "nowrap" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "props": { "id": "wrapId"   }, "children": ["Wrap id — flows across multiple lines as needed."] },
      { "type": "p", "props": { "id": "nowrapId" }, "children": ["Nowrap id — stays on a single line and overflows."] }
    ]
  }
}
