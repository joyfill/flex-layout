{
  "version": 1,
  "style": {
    "#frame":    { "display": "flex", "flexDirection": "column", "gap": { "value": 4, "unit": "px" }, "width": { "value": 160, "unit": "px" } },
    "#wrap":     { "whiteSpace": "normal" },
    "#one-line": { "whiteSpace": "nowrap" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "props": { "id": "wrap"     }, "children": ["Wraps inside the narrow 160px frame across two or three lines."] },
      { "type": "p", "props": { "id": "one-line" }, "children": ["Stays on a single line and overflows the 160px frame."] }
    ]
  }
}
