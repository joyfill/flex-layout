{
  "version": 1,
  "style": {
    "#frame": {
      "width": { "value": 200, "unit": "px" },
      "overflow": "hidden"
    },
    "#text": {
      "overflow": "hidden",
      "whiteSpace": "nowrap",
      "textOverflow": "clip"
    }
  },
  "breakpoints": [
    {
      "conditions": [
        { "type": "feature", "name": "width", "operator": ">=", "value": 768, "unit": "px" }
      ],
      "nodes": {},
      "style": {
        "#frame": { "width": { "value": 320, "unit": "px" } },
        "#text":  { "textOverflow": "ellipsis" }
      }
    }
  ],
  "layout": {
    "type": "div",
    "props": { "id": "frame" },
    "children": [
      { "type": "p", "props": { "id": "text" }, "children": ["The quick brown fox jumps over the lazy dog"] }
    ]
  }
}
