{
  "version": 1,
  "style": {
    "#root": { "flexDirection": "column", "gap": { "value": 8, "unit": "px" } },
    ".frame": {
      "width": { "value": 220, "unit": "px" },
      "overflow": "hidden",
      "backgroundColor": "#F3F4F6"
    },
    ".elided": {
      "overflow": "hidden",
      "whiteSpace": "nowrap",
      "textOverflow": "ellipsis"
    },
    "#serif": { "fontFamily": "LibreBaskerville" },
    "#mono":  { "fontFamily": "GeistMono" }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": { "id": "root" },
    "children": [
      { "type": "div", "props": { "className": ["frame"] }, "children": [
        { "type": "p", "props": { "id": "serif", "className": ["elided"] }, "children": ["The quick brown fox jumps over the lazy dog"] }
      ]},
      { "type": "div", "props": { "className": ["frame"] }, "children": [
        { "type": "p", "props": { "id": "mono",  "className": ["elided"] }, "children": ["The quick brown fox jumps over the lazy dog"] }
      ]}
    ]
  }
}
