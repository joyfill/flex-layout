{
  "version": 1,
  "style": {
    "#root": {
      "width": {
        "value": 400,
        "unit": "px"
      },
      "height": {
        "value": 240,
        "unit": "px"
      },
      "flexDirection": "column",
      "gap": {
        "value": 8,
        "unit": "px"
      }
    },
    "#a": {
      "textOverflow": "ellipsis"
    },
    "#b": {
      "width": {
        "value": 200,
        "unit": "px"
      },
      "textOverflow": "ellipsis"
    },
    "#c": {
      "width": {
        "value": 200,
        "unit": "px"
      },
      "overflow": "hidden",
      "textOverflow": "ellipsis"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": {
      "id": "root"
    },
    "children": [
      {
        "type": "p",
        "props": {
          "id": "a"
        },
        "children": [
          "A: no width, no overflow, no nowrap \u2014 ellipsis has no visible effect (wraps)"
        ]
      },
      {
        "type": "p",
        "props": {
          "id": "b"
        },
        "children": [
          "B: width only, still wraps without whiteSpace nowrap"
        ]
      },
      {
        "type": "p",
        "props": {
          "id": "c"
        },
        "children": [
          "C: width + overflow hidden, still wraps without whiteSpace nowrap"
        ]
      }
    ]
  }
}
