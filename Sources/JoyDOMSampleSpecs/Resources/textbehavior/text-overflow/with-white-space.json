{
  "version": 1,
  "style": {
    "#root": {
      "width": {
        "value": 360,
        "unit": "px"
      },
      "height": {
        "value": 200,
        "unit": "px"
      },
      "flexDirection": "column",
      "gap": {
        "value": 8,
        "unit": "px"
      }
    },
    ".frame": {
      "width": {
        "value": 200,
        "unit": "px"
      },
      "overflow": "hidden",
      "backgroundColor": "#F3F4F6"
    },
    "#wrap": {
      "overflow": "hidden",
      "whiteSpace": "normal",
      "textOverflow": "ellipsis"
    },
    "#nowrap": {
      "overflow": "hidden",
      "whiteSpace": "nowrap",
      "textOverflow": "ellipsis"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": {
      "id": "root"
    },
    "children": [
      {
        "type": "div",
        "props": {
          "className": [
            "frame"
          ]
        },
        "children": [
          {
            "type": "p",
            "props": {
              "id": "wrap"
            },
            "children": [
              "whiteSpace normal: wraps to multiple lines so ellipsis has nothing to truncate"
            ]
          }
        ]
      },
      {
        "type": "div",
        "props": {
          "className": [
            "frame"
          ]
        },
        "children": [
          {
            "type": "p",
            "props": {
              "id": "nowrap"
            },
            "children": [
              "whiteSpace nowrap: collapses to one line and the ellipsis appears"
            ]
          }
        ]
      }
    ]
  }
}
