{
  "version": 1,
  "style": {
    "#frame": {
      "height": {
        "value": 80,
        "unit": "px"
      },
      "width": {
        "value": 200,
        "unit": "px"
      },
      "overflow": "hidden"
    },
    "#elided": {
      "overflow": "hidden",
      "whiteSpace": "nowrap",
      "textOverflow": "ellipsis",
      "color": "#EF4444"
    }
  },
  "breakpoints": [],
  "layout": {
    "type": "div",
    "props": {
      "id": "frame"
    },
    "children": [
      {
        "type": "p",
        "props": {
          "id": "elided"
        },
        "children": [
          "Red ellipsis: the truncated tail dot inherits the text color"
        ]
      }
    ]
  }
}
